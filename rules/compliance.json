{
  "version": "1.0.0",
  "organization": "Agent Governance Open Source",
  "default_policy": "deny_unknown",
  "allowed_actions": [
    "read_file",
    "search_web",
    "send_message"
  ],
  "forbidden_actions": [
    "delete_file_without_backup",
    "execute_sudo_command",
    "modify_system_registry"
  ],
  "data_privacy": {
    "allow_pii_transmission": false,
    "require_encryption_in_transit": true
  },
  "financial_limits": {
    "max_spend_per_transaction_usd": 0.0,
    "require_approval_for_purchases": true
  }
}
